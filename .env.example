# Railway/Backend - обязательно заполнить в Railway Variables
# DATABASE_URL — скопировать из Railway Postgres (Settings → Connect)
DATABASE_URL=

# REDIS_URL — скопировать из Redis Cloud (Configuration → Redis CLI, полный URL)
# Формат: redis://default:PASSWORD@xxx.ec2.cloud.redislabs.com:PORT
# НЕ использовать placeholder "host" — только реальный hostname!
REDIS_URL=

JWT_SECRET=

OPENAI_API_KEY=

# Meilisearch Cloud: Project Settings → URL (только https://, без http://https://)
MEILISEARCH_HOST=
MEILISEARCH_KEY=

QUEUE_PREFIX=locus
LOG_LEVEL=info

# Vercel (frontend) - URL публичного API на Railway
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=

# Опционально

CLOUDFLARE_R2_KEY=replace_me
CLOUDFLARE_R2_SECRET=replace_me
CLOUDFLARE_R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=locus-listing-images
# R2 aliases (production)
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=locus-listing-images
R2_ACCESS_KEY=replace_me
R2_SECRET_KEY=replace_me
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://cdn.example.com
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
YOOKASSA_SHOP_ID=replace_me
YOOKASSA_SECRET_KEY=replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
CDN_BASE_URL=https://cdn.example.com
MEILISEARCH_INDEX_LISTINGS=listings
