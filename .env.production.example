# =============================================================================
# LOCUS — Production Environment Variables
# =============================================================================
# Copy to .env.production and fill with real values.
# NEVER commit .env.production to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Railway, Neon, Supabase, or any PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:5432/locus?sslmode=require

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Railway Redis, Upstash, or any Redis provider
REDIS_URL=redis://default:password@host:6379

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
JWT_SECRET=your-production-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# OpenAI (for AI features: moderation, recommendations, search)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# -----------------------------------------------------------------------------
# SMTP (Email)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@locus.app
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=LOCUS <noreply@locus.app>

# -----------------------------------------------------------------------------
# Object Storage (S3 or Cloudflare R2)
# -----------------------------------------------------------------------------
# Option A: Cloudflare R2
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_KEY=your-r2-access-key
CLOUDFLARE_R2_SECRET=your-r2-secret-key
CLOUDFLARE_R2_BUCKET=locus-listing-images
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://cdn.locus.app

# Option B: AWS S3 (alternative)
# S3_BUCKET=locus-listing-images
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_REGION=eu-central-1
# S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
# STORAGE_PUBLIC_BASE_URL=https://cdn.locus.app

# -----------------------------------------------------------------------------
# API / App URLs (for CORS, webhooks, redirects)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.locus.app
NEXT_PUBLIC_WS_URL=wss://api.locus.app/ws/messages
NEXT_PUBLIC_APP_URL=https://locus.app
APP_BASE_URL=https://locus.app

# -----------------------------------------------------------------------------
# Payments (Stripe / YooKassa)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
YOOKASSA_SHOP_ID=...
YOOKASSA_SECRET_KEY=...
YOOKASSA_RETURN_URL=https://locus.app/payments/return

# -----------------------------------------------------------------------------
# Optional: Meilisearch, Logging, Queue
# -----------------------------------------------------------------------------
MEILISEARCH_HOST=https://...
MEILISEARCH_KEY=...
MEILISEARCH_INDEX_LISTINGS=listings
LOG_LEVEL=info
QUEUE_PREFIX=locus
CDN_BASE_URL=https://cdn.locus.app
