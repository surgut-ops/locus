{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm exec prisma generate && pnpm turbo run build --filter=@locus/api"
  },
  "deploy": {
    "startCommand": "pnpm --filter @locus/api start",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
