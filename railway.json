{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm exec prisma generate && pnpm --filter @locus/api build"
  },
  "deploy": {
    "startCommand": "HOST=0.0.0.0 node apps/api/dist/index.js",
    "healthcheckPath": "/live",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
