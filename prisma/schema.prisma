generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GUEST
  USER
  HOST
  MODERATOR
  ADMIN
}

enum ListingType {
  APARTMENT
  HOUSE
  STUDIO
  ROOM
  VILLA
  HOTEL
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  BLOCKED
}

enum ModerationStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum UserActivityAction {
  VIEW
  SEARCH
  BOOK
}

enum NotificationType {
  NEW_MESSAGE
  NEW_BOOKING
  PAYMENT_SUCCESS
  LISTING_APPROVED
  REFERRAL_INVITED
  REFERRAL_BONUS
}

model User {
  id               String         @id @default(uuid()) @db.Uuid
  email            String         @unique
  phone            String?
  passwordHash     String
  firstName        String
  lastName         String
  avatarUrl        String?
  bio              String?
  role             UserRole       @default(USER)
  rating           Float          @default(0)
  reviewCount      Int            @default(0)
  trustScore       Int            @default(0)
  reputationScore  Int            @default(0)
  emailVerified    Boolean        @default(false)
  phoneVerified    Boolean        @default(false)
  identityVerified Boolean        @default(false)
  isVerified       Boolean        @default(false)
  isBlocked        Boolean        @default(false)
  referralCode     String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  listings       Listing[]      @relation("ListingOwner")
  bookings       Booking[]      @relation("BookingGuest")
  reviews        Review[]       @relation("ReviewAuthor")
  favorites      Favorite[]
  guestChats     Conversation[] @relation("ConversationGuest")
  hostChats      Conversation[] @relation("ConversationHost")
  messages       Message[]      @relation("MessageSender")
  payments       Payment[]
  activities      UserActivity[]
  notifications   Notification[]
  userPreference  UserPreference?
  complaintsAgainst Complaint[]  @relation("ComplaintRespondent")
  complaintsFiled   Complaint[]  @relation("ComplaintComplainant")
  referralsGiven    Referral[]   @relation("Referrer")
  referralsReceived Referral[]   @relation("ReferredUser")
  credits           UserCredit[]

  @@index([email])
  @@index([referralCode])
}

model Referral {
  id         String   @id @default(uuid()) @db.Uuid
  referrerId String   @db.Uuid
  referredId String   @db.Uuid
  rewardPaid Boolean  @default(false)
  createdAt  DateTime @default(now())
  referrer   User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred   User     @relation("ReferredUser", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([referredId])
}

model UserCredit {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  amount    Decimal  @db.Decimal(12, 2)
  source    String
  reference String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum ComplaintStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model Complaint {
  id           String          @id @default(uuid()) @db.Uuid
  complainantId String         @db.Uuid
  respondentId  String         @db.Uuid
  listingId     String?        @db.Uuid
  reason        String
  status        ComplaintStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  complainant   User           @relation("ComplaintComplainant", fields: [complainantId], references: [id], onDelete: Cascade)
  respondent    User           @relation("ComplaintRespondent", fields: [respondentId], references: [id], onDelete: Cascade)

  @@index([respondentId])
  @@index([complainantId])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model Listing {
  id               String           @id @default(uuid()) @db.Uuid
  ownerId          String           @db.Uuid
  title            String
  description      String
  type             ListingType
  status           ListingStatus    @default(DRAFT)
  moderationStatus ModerationStatus @default(PENDING_REVIEW)
  fraudScore       Int?
  pricePerNight  Decimal?        @db.Decimal(12, 2)
  pricePerMonth  Decimal?        @db.Decimal(12, 2)
  currency       String
  city           String
  district       String?
  country        String
  address        String
  latitude       Decimal?        @db.Decimal(10, 7)
  longitude      Decimal?        @db.Decimal(10, 7)
  rooms          Int?
  bedrooms       Int?
  bathrooms      Int?
  area           Decimal?        @db.Decimal(10, 2)
  maxGuests      Int?
  checkInTime    String?
  checkOutTime   String?
  instantBooking Boolean         @default(false)
  rating         Float           @default(0)
  reviewCount    Int             @default(0)
  trustScore     Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  owner          User            @relation("ListingOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  images         ListingImage[]
  amenities      ListingAmenity[]
  bookings       Booking[]
  availability   Availability[]
  reviews        Review[]
  favorites      Favorite[]
  conversations  Conversation[]
  activities     UserActivity[]

  @@index([city])
  @@index([ownerId])
  @@index([pricePerNight])
  @@index([rating])
  @@index([latitude])
  @@index([longitude])
  @@index([status, city])
}

model ListingImage {
  id           String   @id @default(uuid()) @db.Uuid
  listingId    String   @db.Uuid
  url          String
  thumbnailUrl String?
  width        Int?
  height       Int?
  order        Int      @default(0)
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Amenity {
  id        String          @id @default(uuid()) @db.Uuid
  name      String          @unique
  icon      String?
  category  String?
  createdAt DateTime        @default(now())
  listings  ListingAmenity[]
}

model ListingAmenity {
  listingId String  @db.Uuid
  amenityId String  @db.Uuid
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  amenity   Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([listingId, amenityId])
  @@index([amenityId])
}

model Booking {
  id         String        @id @default(uuid()) @db.Uuid
  listingId  String        @db.Uuid
  guestId    String        @db.Uuid
  status     BookingStatus @default(PENDING)
  startDate  DateTime
  endDate    DateTime
  totalPrice Decimal       @db.Decimal(12, 2)
  currency   String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guest      User          @relation("BookingGuest", fields: [guestId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@index([listingId])
  @@index([guestId])
}

model Availability {
  id            String   @id @default(uuid()) @db.Uuid
  listingId     String   @db.Uuid
  date          DateTime
  isAvailable   Boolean  @default(true)
  priceOverride Decimal? @db.Decimal(12, 2)
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
  @@index([listingId])
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  listingId String   @db.Uuid
  authorId  String   @db.Uuid
  rating    Int      @db.SmallInt
  comment   String?
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([authorId])
}

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  listingId String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model Conversation {
  id        String    @id @default(uuid()) @db.Uuid
  listingId String    @db.Uuid
  guestId   String    @db.Uuid
  hostId    String    @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  guest     User      @relation("ConversationGuest", fields: [guestId], references: [id], onDelete: Cascade)
  host      User      @relation("ConversationHost", fields: [hostId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([listingId])
  @@index([guestId])
  @@index([hostId])
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  senderId       String       @db.Uuid
  text           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Payment {
  id        String        @id @default(uuid()) @db.Uuid
  bookingId String        @db.Uuid
  userId    String        @db.Uuid
  amount    Decimal       @db.Decimal(12, 2)
  currency  String
  status    PaymentStatus @default(PENDING)
  provider  String
  createdAt DateTime      @default(now())
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([userId])
}

model UserActivity {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @db.Uuid
  listingId String?            @db.Uuid
  action    UserActivityAction
  metadata  Json?
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing?           @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([listingId])
}

model UserPreference {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @db.Uuid
  favoriteCities Json     @default("[]")
  priceMin       Decimal? @db.Decimal(12, 2)
  priceMax       Decimal? @db.Decimal(12, 2)
  propertyTypes  Json     @default("[]")
  amenities      Json     @default("[]")
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
